---
/**
 * WaveformBar.astro
 * -----------------
 *
 * The singleton mount component for `@arraypress/waveform-bar`.
 *
 * Renders **one** persistent host `<div>` (with `transition:persist`
 * so it survives Astro view transitions) and an inline init script
 * that calls `window.WaveformBar.init(config)` exactly **once** per
 * page session. The init is idempotent: subsequent `astro:page-load`
 * events are a no-op, because waveform-bar's `init()` destroys and
 * rebuilds the bar on every call (restarting/re-buffering the playing
 * audio) — which would defeat `transition:persist`. The bar library
 * itself injects the visible UI (`.waveform-bar`, `.wb-queue-panel`)
 * into `<body>` at runtime — we provide a stable host element so view
 * transitions don't tear it down on every navigation.
 *
 * ## Render this exactly ONCE
 *
 * Put it in your root layout, after your main content:
 *
 * ```astro
 * ---
 * // src/layouts/Layout.astro
 * import '@arraypress/waveform-player/dist/waveform-player.css';
 * import '@arraypress/waveform-bar/dist/waveform-bar.css';
 * import wfpJsUrl from '@arraypress/waveform-player/dist/waveform-player.min.js?url';
 * import wbJsUrl  from '@arraypress/waveform-bar/dist/waveform-bar.min.js?url';
 * import { WaveformBar } from '@arraypress/waveform-bar-astro';
 * ---
 * <html>
 *   <head>
 *     <script src={wfpJsUrl} is:inline></script>
 *     <script src={wbJsUrl}  is:inline></script>
 *   </head>
 *   <body>
 *     <slot />
 *     <WaveformBar config={{ persist: true, continuous: true }} />
 *   </body>
 * </html>
 * ```
 *
 * ## Why a singleton?
 *
 * The core library installs a global on `window.WaveformBar`. There
 * can only be one bar per page — calling `init()` twice destroys the
 * first instance. Rendering this component more than once in the
 * same page tree will result in repeated init calls, the last one
 * wins. Don't do that.
 *
 * ## What this component does NOT do
 *
 * It does not load the library's JS or CSS — you control that in
 * your layout's `<head>`. The bar library also has a strict
 * dependency on `@arraypress/waveform-player`; both scripts must be
 * present before this component's init script runs.
 *
 * It also does not provide any theme-specific styling (CSS variable
 * bridges to your design tokens, close-button affordances, etc.).
 * Those belong in your application layer because they're rarely
 * portable — write them next to where you mount this component.
 *
 * @example Bare-bones
 *   <WaveformBar />
 *
 * @example With config + custom host id
 *   <WaveformBar
 *     hostId="my-audio-bar-host"
 *     config={{
 *       persist: true,
 *       autoResume: true,
 *       continuous: true,
 *       showQueue: true,
 *       maxMeta: 1,
 *       storageKey: 'my-app-bar',
 *       actions: {
 *         favorite: { endpoint: '/api/favorites' },
 *         cart:     { endpoint: '/api/cart' },
 *       },
 *     }}
 *   />
 */

import type { WaveformBarProps } from './types';

const {
	config = {},
	persist = true,
	hostId = 'waveform-bar-host',
	class: className,
} = Astro.props as WaveformBarProps;

/**
 * Serialise the config into the inline script. Astro's `define:vars`
 * handles this safely (escapes `</script>`, encodes Unicode, etc.) so
 * we don't have to JSON.stringify by hand. Anything that can't round
 * through `JSON.parse(JSON.stringify(...))` (functions, Dates,
 * regexps) is dropped — see the types file for which fields are
 * function-bearing and therefore unavailable from Astro.
 */
const wbConfig = config;
---

{/*
  The `transition:persist` directive is applied at the markup level via
  two branches rather than with a conditional expression on the attribute.
  Astro's container renderer emits a dynamic value
  (`transition:persist={cond ? 'name' : undefined}` — or even a plain
  variable) as the *literal source text* instead of evaluating it, which
  breaks the host element. Splitting into a persisted branch (string
  literal name) and a non-persisted branch (attribute omitted) keeps the
  real output correct: the host carries `transition:persist="waveform-bar"`
  when enabled and drops it entirely when disabled.
*/}
{persist ? (
	<div
		id={hostId}
		class:list={['wb-host', className]}
		transition:persist="waveform-bar"
	></div>
) : (
	<div id={hostId} class:list={['wb-host', className]}></div>
)}

<script is:inline define:vars={{ WB_CFG: wbConfig, WB_HOST_ID: hostId }}>
	/**
	 * Inline init runtime for `<WaveformBar>`.
	 *
	 * Initialises the bar **exactly once** per page session. We listen
	 * for `astro:page-load` (and `DOMContentLoaded` on first paint) so
	 * the bar comes up as soon as the library is available, but the
	 * actual `init(config)` call is idempotent — it fires a single time
	 * and every later navigation is a no-op.
	 *
	 * This matters because waveform-bar's `init()` calls `destroy()`
	 * first (see core init: `if (this.isInitialized) this.destroy()`),
	 * so re-initialising on each `astro:page-load` would tear down and
	 * rebuild the bar — restarting/re-buffering the currently-playing
	 * audio and defeating `transition:persist`. The persisted host (and
	 * the bar relocated into it) already survives navigations, so on
	 * subsequent page loads we leave it untouched.
	 *
	 * The init call is guarded — if the bar library hasn't loaded yet
	 * (consumer forgot the script tag), we log a one-time warning and do
	 * NOT mark init as done, so a later `astro:page-load` can retry once
	 * the script is present.
	 *
	 * After init we move the library's `.waveform-bar` element into
	 * our `wb-host` div if it isn't already there. The bar library
	 * appends to `<body>` by default; relocating it under the persist
	 * host means view transitions keep it on screen.
	 */
	(function () {
		if (window.__wbAstroInitBound) return;
		window.__wbAstroInitBound = true;

		var loggedMissing = false;

		function initBar() {
			/* Idempotent: only ever init the bar once. waveform-bar's
			 * init() destroys + rebuilds, so re-running it on every
			 * navigation would restart the playing audio and undo
			 * transition:persist. Once initialised we no-op. */
			if (window.__apWaveformBarInited) return;

			if (!window.WaveformBar) {
				if (!loggedMissing) {
					console.warn(
						'[WaveformBarAstro] window.WaveformBar is not loaded yet. ' +
						'Did you forget to load @arraypress/waveform-bar and its ' +
						'@arraypress/waveform-player peer dependency? Will retry on ' +
						'the next astro:page-load.'
					);
					loggedMissing = true;
				}
				return;
			}

			try {
				window.WaveformBar.init(WB_CFG);
			} catch (err) {
				console.error('[WaveformBarAstro] WaveformBar.init() failed:', err);
				return;
			}

			/* Mark init as done only after a successful init() so that a
			 * failed/early attempt (e.g. library not yet loaded) can be
			 * retried on the next astro:page-load. */
			window.__apWaveformBarInited = true;

			/* Relocate the bar element into our persist host so
			 * view transitions keep it onscreen between navigations.
			 * The library renders into <body> by default. */
			var host = document.getElementById(WB_HOST_ID);
			var bar = document.querySelector('.waveform-bar');
			if (host && bar && bar.parentElement !== host) {
				host.appendChild(bar);
			}

			/* NOTE: waveform-bar also appends its `.wb-queue-panel` to
			 * <body>, separately from `.waveform-bar`. We don't relocate
			 * it into the persist host because doing so reliably needs a
			 * core waveform-bar `container` option that doesn't exist
			 * yet. Pending that option the queue panel stays on <body>;
			 * it is recreated on a fresh init, so the once-only init
			 * above keeps it stable across navigations regardless. */
		}

		document.addEventListener('astro:page-load', initBar);
		if (document.readyState !== 'loading') {
			initBar();
		} else {
			document.addEventListener('DOMContentLoaded', initBar);
		}
	})();
</script>
